# Optional overrides. The suite runs out of the box against the public
# defaults below — copying this file is NOT required to run the tests.

# API under test (contract/schema testing target)
JSONPLACEHOLDER_BASE_URL=https://jsonplaceholder.typicode.com

# E2E under test
HACKERNEWS_BASE_URL=https://news.ycombinator.com
HACKERNEWS_SEARCH_BASE_URL=https://hn.algolia.com

# Request timeout (ms) applied to API calls
API_TIMEOUT_MS=15000
