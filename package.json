{
  "name": "playwright-qa-portfolio",
  "version": "1.0.0",
  "description": "QA automation portfolio: API contract testing (JSONPlaceholder) and E2E testing (Hacker News) with Playwright + TypeScript.",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "playwright test",
    "test:api": "playwright test --project=api",
    "test:e2e": "playwright test --project=e2e-chromium --project=e2e-firefox --project=e2e-webkit",
    "test:e2e:chromium": "playwright test --project=e2e-chromium",
    "test:headed": "playwright test --project=e2e-chromium --headed",
    "test:debug": "playwright test --debug",
    "report": "playwright show-report",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.18.0",
    "@typescript-eslint/parser": "^8.18.0",
    "dotenv": "^16.4.7",
    "eslint": "^9.16.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript": "^5.7.2",
    "zod": "^3.24.1"
  }
}
